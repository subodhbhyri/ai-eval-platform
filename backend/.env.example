# ── Database ──────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/eval_dashboard

# ── Redis ─────────────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0

# ── Kafka ─────────────────────────────────────────────────────────────────────
# Start Kafka locally: docker compose -f docker/docker-compose.dev.yml up -d
# Then set KAFKA_ENABLED=true to activate the consumer and SSE stream.
# Leave false (default) to run the app without Kafka — all Kafka code is gated.
KAFKA_ENABLED=true
KAFKA_BOOTSTRAP_SERVERS=localhost:9092

# ── LLM API Keys ──────────────────────────────────────────────────────────────
OPENAI_API_KEY=sk-...
ANTHROPIC_API_KEY=sk-ant-...
GOOGLE_API_KEY=AIza...

# ── App ───────────────────────────────────────────────────────────────────────
DEBUG=true
MAX_CONCURRENT_EVALUATIONS=3
